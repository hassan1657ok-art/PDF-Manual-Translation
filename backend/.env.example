# ============================================
# Backend Environment Configuration Example
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files with real API keys!

# --------------------------------------------
# Required: AI Translation API
# --------------------------------------------
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------------------
# Optional: File Storage Paths
# --------------------------------------------
# Directory for uploaded PDF files
UPLOAD_DIR=/tmp/uploads

# Directory for translated output files
OUTPUT_DIR=/tmp/output

# --------------------------------------------
# Optional: Upload Limits
# --------------------------------------------
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# --------------------------------------------
# Optional: CORS Settings
# --------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# --------------------------------------------
# Optional: Logging
# --------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO